# ============================================================================
# NEXTAUTH CONFIGURATION (REQUIRED)
# ============================================================================

# Generate a random secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET=change_me_to_random_32_character_string_minimum

# URL where application is deployed (localhost for development)
NEXTAUTH_URL=http://localhost:3000

# ============================================================================
# DATABASE CONFIGURATION (REQUIRED)
# ============================================================================

# PostgreSQL Setup (RECOMMENDED - Uncomment to use)
# Create database first: createdb ava_db
DATABASE_URL=postgresql://postgres:password@localhost:5432/ava_db
DIRECT_URL=postgresql://postgres:password@localhost:5432/ava_db

# SQLite Setup (Alternative - Comment out PostgreSQL above, uncomment below)
# DATABASE_URL=file:./prisma/dev.db

# ============================================================================
# BLOCKCHAIN CONFIGURATION (CHOOSE ONE - Required)
# ============================================================================

# 1. SIMULATION MODE (Default - Recommended for development)
# No blockchain setup required. Generates mock transaction hashes.
BLOCKCHAIN_TYPE=SIMULATION

# 2. ETHEREUM MODE (Requires Alchemy API key + deployed contract)
# Uncomment lines below and fill in values to enable Ethereum integration
# BLOCKCHAIN_TYPE=ETHEREUM
# ETHEREUM_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY
# ETHEREUM_API_KEY=YOUR_ALCHEMY_API_KEY
# ETHEREUM_CONTRACT_ADDRESS=0xYourDeployedSmartContractAddress
# ETHEREUM_PRIVATE_KEY=YourPrivateKeyWithoutLeadingZero

# 3. HYPERLEDGER FABRIC MODE (Not yet implemented - Use SIMULATION)
# Placeholder for future Hyperledger Fabric integration
# BLOCKCHAIN_TYPE=FABRIC
# FABRIC_CCP_PATH=./connection-org1.json
# FABRIC_WALLET_PATH=./wallet
# FABRIC_IDENTITY=admin
# FABRIC_CHANNEL=mychannel
# FABRIC_CHAINCODE=basic
# FABRIC_CONTRACT=basic

# ============================================================================
# OAUTH PROVIDERS (OPTIONAL - Leave empty to disable provider)
# ============================================================================

# Google OAuth Setup:
# 1. Visit: https://console.cloud.google.com/apis/dashboard
# 2. Create OAuth 2.0 credentials
# 3. Set Authorized redirect: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Facebook OAuth Setup:
# 1. Visit: https://developers.facebook.com/apps/
# 2. Create app with Facebook Login product
# 3. Set Redirect URIs: http://localhost:3000/api/auth/callback/facebook
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# GitHub OAuth Setup:
# 1. Visit: https://github.com/settings/developers
# 2. Create new OAuth App
# 3. Set Authorization callback: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ============================================================================
# OFFLINE FALLBACK CREDENTIALS (OPTIONAL)
# ============================================================================

# If database is unavailable, these credentials allow login
# ⚠️  WARNING: Change these values for ANY non-development environment!
# Demo Credentials (Development Only):
OFFLINE_ADMIN_EMAIL=admin@ava.com
OFFLINE_ADMIN_PASSWORD=admin123

OFFLINE_USER_EMAIL=user@ava.com
OFFLINE_USER_PASSWORD=user123

# ============================================================================
# OPTIONAL FEATURES
# ============================================================================

# IPFS/Pinata Configuration (For future document storage)
# PINATA_API_KEY=
# PINATA_API_SECRET=

# Node Environment
NODE_ENV=development
# NODE_ENV=production

# Debug Logging (Development only)
# DEBUG=ava:*

# ============================================================================
# SETUP INSTRUCTIONS
# ============================================================================
#
# 1. Copy this file to .env:
#    cp .env.example .env
#
# 2. Edit .env and configure:
#    - NEXTAUTH_SECRET (generate random value)
#    - DATABASE_URL (PostgreSQL recommended)
#    - BLOCKCHAIN_TYPE (SIMULATION for dev)
#
# 3. Setup database:
#    npm run db:push
#
# 4. Seed test data (optional):
#    npx ts-node prisma/seed.ts
#
# 5. Start development server:
#    npm run dev
#
# Access: http://localhost:3000
# Login: admin@ava.com / admin123 (offline mode)
#
# ============================================================================
